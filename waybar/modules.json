{
  "hyprland/workspaces": {
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "format": "{}",
    "format-icons": {
      "urgent": "",
      "active": "",
      "default": ""
    },
    "persistent-workspaces": {
      "*": 5
    }
  },

  "hyprland/window": {
    "rewrite": {
      "(.*) - Zen Browser": "$1",
      "(.*) - Brave": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Outlook": "$1",
      "(.*) Microsoft Teams": "$1"
    },
    "separate-outputs": true
  },

  "custom/appmenu": {
    "format": "¾░Żć",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings",
    "on-click": "rofi -show drun -theme ~/.config/rofi/launcher.rasi",
    "on-click-right": "~/.config/notscripter/scripts/keybindings.sh",
    "tooltip": false
  },

  "custom/exit": {
    "format": "’Ćæ",
    "tooltip-format": "Powermenu",
    "on-click": "wlogout -b 4",
    "tooltip": false
  },

  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "¾▒ģ½",
      "none": "¾░éÜ",
      "dnd-notification": "¾▒ģ½",
      "dnd-none": "¾░éø",
      "inhibited-notification": "’éó",
      "inhibited-none": "’éó",
      "dnd-inhibited-notification": "’éó",
      "dnd-inhibited-none": "’éó"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

  "tray": {
    "icon-size": 24,
    "spacing": 8
  },

  "clock": {
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format": "¾░źö {0:%H:%M}",
    "format-alt": "¾░źö {0:%H:%M}  ’ü│ {0:%d-%m-%Y}"
  },

  "hyprland/language": {
    "format": "/ K {short}"
  },

  "network": {
    "format": "{ifname}",
    "format-wifi": "’ć½  {signalStrength}% ’ä║ {bandwidthDownBytes} ’ä╣ {bandwidthUpBytes} ",
    "format-ethernet": "’Ŗć  ’ä║ {bandwidthDownBytes} ’ä╣ {bandwidthUpBytes} ",
    "format-disconnected": "¾░▓ø ",
    "tooltip-format": "’Ŗć  {ifname} via {gwaddri}",
    "tooltip-format-wifi": "’ć½   {essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "’āü  {ifname} ({ipaddr}/{cidr})",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "interval": 1,
    "on-click": "nm-connection-editor"
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}   {capacity}%",
    "format-charging": "’Ś¦  {capacity}%",
    "format-plugged": "’ć”  {capacity}%",
    "format-alt": "{icon}  {time}",
    "format-icons": ["’ēä ", "’ēā ", "’ēé ", "’ēü ", "’ēĆ "]
  },

  "bluetooth": {
    "format-disabled": "",
    "format-off": "",
    "interval": 30,
    "on-click": "blueman-manager",
    "format-no-controller": ""
  },

  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "tooltip": true,
    "format-icons": {
      "activated": "’Åü",
      "deactivated": "’ĆŻ"
    },
    "on-click-right": "hyprlock"
  }
}
