"$schema" = 'https://starship.rs/config-schema.json'

add_newline = true
palette = "akantha"

format = """
[░▒▓](base)\
[ 󰣇 ](bg:base fg:mauve)\
[](bg:mantle fg:base)\
$directory\
[](fg:mantle bg:crust)\
$git_branch\
$git_status\
[](fg:crust bg:crust)\
$nodejs\
$rust\
$golang\
$php\
[](fg:crust bg:crust)\
$time\
[ ](fg:crust)\
\n$character"""

[directory]
style = "fg:mauve bg:mantle"
format = "[ $path ]($style)"
truncation_length = 3
truncation_symbol = "…/"

[directory.substitutions]
"Documents" = "󰈙 "
"Downloads" = " "
"Music" = " "
"Pictures" = " "
"Media" = " "

[git_branch]
symbol = ""
style = "bg:crust"
format = '[[ $symbol $branch ](fg:mauve bg:crust)]($style)'

[git_status]
style = "bg:crust"
format = '[[($all_status$ahead_behind )](fg:mauve bg:crust)]($style)'

[nodejs]
symbol = ""
style = "bg:mantle"
format = '[[ $symbol ($version) ](fg:mauve bg:mantle)]($style)'

[rust]
symbol = ""
style = "bg:mantle"
format = '[[ $symbol ($version) ](fg:mauve bg:mantle)]($style)'

[golang]
symbol = ""
style = "bg:mantle"
format = '[[ $symbol ($version) ](fg:mauve bg:mantle)]($style)'

[php]
symbol = ""
style = "bg:mantle"
format = '[[ $symbol ($version) ](fg:mauve bg:mantle)]($style)'

[time]
disabled = false
time_format = "%R" # Hour:Minute Format
style = "bg:crust"
format = '[[  $time ](fg:mauve bg:crust)]($style)'

[palettes.akantha]
rosewater = "#f5e0dc"
flamingo = "#f2cdcd"
pink = "#f5c2e7"
mauve = "#cba6f7"
red = "#f38ba8"
maroon = "#eba0ac"
peach = "#fab387"
yellow = "#f9e2af"
green = "#a6e3a1"
teal = "#94e2d5"
sky = "#89dceb"
sapphire = "#74c7ec"
blue = "#89b4fa"
lavender = "#b4befe"
text = "#cdd6f4"
subtext1 = "#bac2de"
subtext0 = "#a6adc8"
overlay2 = "#9399b2"
overlay1 = "#7f849c"
overlay0 = "#6c7086"
surface2 = "#585b70"
surface1 = "#45475a"
surface0 = "#313244"
base = "#1e1e2e"
mantle = "#181825"
crust = "#11111b"
